import java.util.Scanner;
class Employee 
{
    protected int empId;
    protected String name;
    protected double basicSalary;
    
    public Employee(int empId, String name, double basicSalary) 
    {
        this.empId = empId;
        this.name = name;
        this.basicSalary = basicSalary;
    }
    
    public void displayDetails() 
    {
        System.out.println("Employee ID: " + empId);
        System.out.println("Name: " + name);
        System.out.println("Basic Salary: " + basicSalary);
    }
    
    public double calculateSalary() 
    {
        return basicSalary;
    }
}

class FullTimeEmployee extends Employee 
{
    private double hra;
    private double da;
    public FullTimeEmployee(int empId, String name, double basicSalary, double hra, double da) 
    {
        super(empId, name, basicSalary);
        this.hra = hra;
        this.da = da; 
    } 
    
    @Override 
    public double calculateSalary() 
    { 
        return basicSalary + hra + da; 
    } 
    
    public void displayFullTimeDetails() 
    { 
        displayDetails(); 
        System.out.println("HRA: " + hra); 
        System.out.println("DA: " + da); 
        System.out.println("Total Salary: " + calculateSalary()); 
    } 
} 

class PartTimeEmployee extends Employee 
{ 
    private int workingHours; 
    private double hourlyRate; 
    public PartTimeEmployee(int empId, String name, double basicSalary, int workingHours, double hourlyRate) 
    { 
        super(empId, name, basicSalary); 
        this.workingHours = workingHours; 
        this.hourlyRate = hourlyRate; 
    } 
    
    @Override public double calculateSalary() 
    { 
        return workingHours * hourlyRate; 
    } 
    
    public void displayPartTimeDetails() 
    { 
        displayDetails(); 
        System.out.println("Working Hours: " + workingHours); 
        System.out.println("Hourly Rate: " + hourlyRate); 
        System.out.println("Total Salary: " + calculateSalary()); 
    } 
} 
public class EmployeeSalaryManagement 
{ 
    public static void main(String[] args) 
    { 
        Scanner sc = new Scanner(System.in); 
        System.out.println("Select Employee Type:"); 
        System.out.println("1. Full-Time Employee"); 
        System.out.println("2. Part-Time Employee"); 
        int choice = sc.nextInt(); 
        System.out.print("Enter Employee ID: "); 
        int id = sc.nextInt(); 
        sc.nextLine(); 
        System.out.print("Enter Name: "); 
        String name = sc.nextLine(); 
        System.out.print("Enter Basic Salary: "); 
        double basicSalary = sc.nextDouble(); 
        
        if (choice == 1) 
        { 
            System.out.print("Enter HRA: "); 
            double hra = sc.nextDouble(); 
            System.out.print("Enter DA: "); 
            double da = sc.nextDouble(); 
            
            FullTimeEmployee fte = new FullTimeEmployee(id, name, basicSalary, hra, da); 
            System.out.println("\n--- Full-Time Employee Details ---"); 
            fte.displayFullTimeDetails(); 
        } 
        else if (choice == 2) 
        { 
            System.out.print("Enter Working Hours: "); 
            int hours = sc.nextInt(); 
            System.out.print("Enter Hourly Rate: "); 
            double rate = sc.nextDouble(); 
            PartTimeEmployee pte = new PartTimeEmployee(id, name, basicSalary, hours, rate); 
            System.out.println("\n--- Part-Time Employee Details ---"); 
            pte.displayPartTimeDetails(); 
        } 
        else 
        { 
            System.out.println("Invalid choice!"); 
        } 
        sc.close(); 
    } 
}
